import requests
import json
import struct


url = "https://datos.aresep.go.cr/ws.datosabiertos/Services/IA/Asadas.svc/ObtenerInformacionUbicacionAsadas"

respuesta = requests.get(url)

datos = respuesta.json()

with open("asadas.json", "w", encoding="utf-8") as archivo:
    json.dump(datos, archivo, indent=4, ensure_ascii=False)
print("Archivo JSON guardado correctamente.")

def crear_binario_y_indice(json_path='asadas.json', bin_path='asadas.bin', idx_path='asadas.idx'):
    with open(json_path, 'r', encoding='utf-8') as f:
        datos = json.load(f)

    registros = datos if isinstance(datos, list) else datos.get('List', datos.get('d', datos))

    if not isinstance(registros, list):
        registros = list(registros)

    with open(bin_path, 'wb') as bfile, open(idx_path, 'wb') as idxfile:
        for rec in registros:
            try:
                id_asada = int(rec.get('id_Asada') or rec.get('id_asada') or rec.get('ID_ASADA') )
            except Exception:
                continue
            pos = bfile.tell()
            raw = json.dumps(rec, ensure_ascii=False).encode('utf-8')
            bfile.write(struct.pack('<I', id_asada))
            bfile.write(struct.pack('<I', len(raw)))
            bfile.write(raw)
            idxfile.write(struct.pack('<IQ', id_asada, pos))

    print(f"Archivo binario '{bin_path}' y índice '{idx_path}' creados.")


def json_a_binario(json_path='asadas.json', bin_path='asadas.bin'):
    with open(json_path, 'r', encoding='utf-8') as f:
        datos = json.load(f)
    
    registros = datos if isinstance(datos, list) else datos.get('List', datos.get('d', datos))
    if not isinstance(registros, list):
        registros = list(registros)
    
    with open(bin_path, 'wb') as bfile:
        bfile.write(struct.pack('<I', len(registros)))  # Cantidad de registros
        for rec in registros:
            raw = json.dumps(rec, ensure_ascii=False).encode('utf-8')
            bfile.write(struct.pack('<I', len(raw)))
            bfile.write(raw)
    
    print(f"JSON convertido a binario: '{bin_path}'")
    return bin_path


def obtener_por_id(id_objeto, bin_path='asadas.bin', idx_path='asadas.idx'):

        with open(idx_path, 'rb') as idxfile:
            while True:
                data = idxfile.read(12)  # 4 bytes para id_asada + 8 bytes para posición
                if not data:
                    break
                id_asada, pos = struct.unpack('<IQ', data)
                if id_asada == int(id_objeto):
                    with open(bin_path, 'rb') as bfile:
                        bfile.seek(pos)
                        id_leido = struct.unpack('<I', bfile.read(4))[0]
                        longitud = struct.unpack('<I', bfile.read(4))[0]
                        raw = bfile.read(longitud)
                        return json.loads(raw.decode('utf-8'))


if __name__ == '__main__':
    # Crear binario e índice basados en el JSON descargado
    crear_binario_y_indice()

    # Si se pasa un id por línea de comandos, mostrar la asada correspondiente
    id_consulta = input("Ingrese el id_Asada a consultar: ")
    resultado = obtener_por_id(id_consulta)
    if resultado:
        print(json.dumps(resultado, ensure_ascii=False, indent=4))
    else:
        print(f"No se encontró la ASADA con id_Asada {id_consulta}.")